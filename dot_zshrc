# For profiling
#zmodload zsh/zprof

for file in ~/.{path,exports,aliases,functions,extra,rbenvrc}; do
  [ -r "$file" ] && [ -f "$file" ] && source "$file";
done;
unset file;


if [ "$TERM_PROGRAM" != "Apple_Terminal" ]; then
  eval "$(oh-my-posh init zsh)"
fi

test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

export NVM_DIR="${HOME}/.nvm"

_nvm_load() {
  [[ -n "$NVM_LOADED" ]] && return
  [ -s "$HOMEBREW_PREFIX/opt/nvm/nvm.sh" ] && \. "$HOMEBREW_PREFIX/opt/nvm/nvm.sh"
  [ -s "$HOMEBREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm" ] && \. "$HOMEBREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm"
  NVM_LOADED=1
}

# Lazy stub: only load nvm.sh on first explicit nvm call
nvm() { unset -f nvm; _nvm_load; nvm "$@"; }

# Auto-switch: only call nvm use when the nearest .nvmrc actually changes
_nvm_current_nvmrc="__unset__"
_nvm_auto_use() {
  local dir="$PWD" nvmrc=""
  while [[ "$dir" != "/" ]]; do
    [[ -f "$dir/.nvmrc" ]] && nvmrc="$dir/.nvmrc" && break
    dir="${dir:h}"
  done
  if [[ "$nvmrc" != "$_nvm_current_nvmrc" ]]; then
    _nvm_current_nvmrc="$nvmrc"
    _nvm_load
    [[ -n "$nvmrc" ]] && nvm use
  fi
}

autoload -U add-zsh-hook
add-zsh-hook chpwd _nvm_auto_use
_nvm_auto_use

eval "$(direnv hook zsh)"

# Return terminal to "emacs" mode so ctrl+a, ctrl+k etc work
bindkey -e

# AUTOCOMPLETION
# initialize autocompletion
autoload -U compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

# history setup
setopt APPEND_HISTORY
setopt SHARE_HISTORY
HISTFILE=$HOME/.zhistory
SAVEHIST=32768
HISTSIZE=32768
setopt HIST_EXPIRE_DUPS_FIRST
setopt EXTENDED_HISTORY

# autocompletion using arrow keys (based on history)
bindkey '\e[A' history-search-backward
bindkey '\e[B' history-search-forward

# For profiling
#zprof

# ctrlk for tmux
bindkey \^K kill-line

# ---- FZF -----

# Set up fzf key bindings and fuzzy completion
eval "$(fzf --zsh)"

# -- Use fd instead of find --

export FZF_DEFAULT_COMMAND="fd --hidden --strip-cwd-prefix --exclude .git"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type=d --hidden --strip-cwd-prefix --exclude .git"

# Use fd (https://github.com/sharkdp/fd) for listing path candidates.
# - The first argument to the function ($1) is the base path to start traversal
# - See the source code (completion.{bash,zsh}) for the details.
_fzf_compgen_path() {
  fd --hidden --exclude .git . "$1"
}

# Use fd to generate the list for directory completion
_fzf_compgen_dir() {
  fd --type=d --hidden --exclude .git . "$1"
}

# Previews with fzf
show_file_or_dir_preview="if [ -d {} ]; then eza --tree --color=always {} | head -200; else bat -n --color=always --line-range :500 {}; fi"

export FZF_CTRL_T_OPTS="--preview '$show_file_or_dir_preview'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always {} | head -200'"

# Advanced customization of fzf options via _fzf_comprun function
# - The first argument to the function is the name of the command.
# - You should make sure to pass the rest of the arguments to fzf.
_fzf_comprun() {
  local command=$1
  shift

  case "$command" in
    cd)           fzf --preview 'eza --tree --color=always {} | head -200' "$@" ;;
    export|unset) fzf --preview "eval 'echo ${}'"         "$@" ;;
    ssh)          fzf --preview 'dig {}'                   "$@" ;;
    *)            fzf --preview "$show_file_or_dir_preview" "$@" ;;
  esac
}

# Zoxide (better cd)
[ -z "$DISABLE_ZOXIDE" ] && eval "$(zoxide init --cmd cd zsh)"

eval "$(rbenv init - zsh)"
eval "$(/opt/homebrew/bin/brew shellenv)"
