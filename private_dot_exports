# Make vim the default editor
 export EDITOR="nvim";
 export BUNDLE_EDITOR="nvim";

# History size (also set in .zshrc via SAVEHIST)
export HISTSIZE=32768;

LANG="en_US.UTF-8"
LC_COLLATE="en_US.UTF-8"
LC_CTYPE="en_US.UTF-8"
LC_MESSAGES="en_US.UTF-8"
LC_MONETARY="en_US.UTF-8"
LC_NUMERIC="en_US.UTF-8"
LC_TIME="en_US.UTF-8"
LC_ALL="en_US.UTF-8"
export LANG LC_COLLATE LC_CTYPE LC_MESSAGES LC_MONETARY LC_NUMERIC LC_TIME LC_ALL

# Highlight section titles in manual pages
export LESS_TERMCAP_md=$'\e[1;33m';

# Don’t clear the screen after quitting a manual page
export MANPAGER="less -X";

# Link Homebrew casks in `/Applications` rather than `~/Applications`
export HOMEBREW_CASK_OPTS="--appdir=/Applications";

export NODE_VERSION_PREFIX=v
export NODE_VERSIONS="$NVM_DIR/versions/node"

export ITERM2_SQUELCH_MARK=1

export GOPATH=$HOME/go

# Resolve Homebrew prefix once (avoids 8 slow brew --prefix <formula> subshells)
HOMEBREW_PREFIX="$(/opt/homebrew/bin/brew --prefix)"

export PATH=$HOMEBREW_PREFIX/bin:$PATH
export PATH=$PATH:$GOPATH/bin
export PATH=$HOMEBREW_PREFIX/opt/postgresql@13/bin:$PATH
export PATH="$HOMEBREW_PREFIX/opt/openssl@3/bin:$PATH"
# Gem bindir is handled by rbenv shims

# For building with rbenv including jemalloc and other inputs from homebrew
export CPPFLAGS="-I$HOMEBREW_PREFIX/opt/jemalloc/include"
export CFLAGS="-I$HOMEBREW_PREFIX/opt/jemalloc/include"
export LDFLAGS="-L$HOMEBREW_PREFIX/opt/jemalloc/lib"

# Ruby building options
export RUBY_CONFIGURE_OPTS="--with-jemalloc"

# Jemalloc for Ruby (LD_PRELOAD removed — no effect on macOS)
export MALLOC_CONF="dirty_decay_ms:1000,narenas:2,background_thread:false,stats_print:false"

# Fix for may have been in progress in another thread when fork() was called
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# Increase number of parellel build processes
export MAKEOPTS="-j 10"

export CLAUDE_CODE_NO_FLICKER=1
