# syntax=docker/dockerfile:1.6
#
# Ralph sandbox image. Stack-agnostic — the base image is parameterized.
#
# Security properties (enforced here + by the launcher's `docker run` flags):
#   - Two non-root users: `ralph` (uid 1000, runs claude) and `ralph-tools`
#     (uid 1001, runs the MCP server).
#   - No NOPASSWD sudo; no sudoers entry at all. Firewall runs in a separate
#     privileged init container — see `init-firewall.sh`.
#   - The MCP server binary lives at /opt/ralph-tools/, root-owned, mode 0755.
#     The `ralph` user cannot modify it.
#   - claude settings come from /etc/claude-defaults/, bind-mounted ro at
#     runtime to /home/ralph/.claude/. Loop cannot rewrite hooks.
#
# Image is built per-project by `bin/ralph build`, parameterized by:
#   BASE_IMAGE             e.g. "ruby:4.0.2" / "node:20-bookworm" / "python:3.12-slim"
#   RALPH_TOOLS_VERSION    pinned semver of @ralph/tools
#   RALPH_TOOLS_SHA256     tarball checksum
#   MCP_INSTALL_SCRIPT     generated shell snippet to install project-declared MCPs
#   CLAUDE_CODE_VERSION    pinned semver of @anthropic-ai/claude-code

ARG BASE_IMAGE=node:20-bookworm
FROM ${BASE_IMAGE} AS base

ARG TZ
ENV TZ="$TZ"
ENV DEBIAN_FRONTEND=noninteractive

# ---- Minimum system packages for the loop ----
# No gh / vim / nano / fzf / man-db / zsh — those are for interactive shells.
# With Bash denied at the tool surface, the LLM has no use for them.
RUN apt-get update && apt-get install -y --no-install-recommends \
      git \
      ca-certificates \
      curl \
      jq \
  && apt-get clean && rm -rf /var/lib/apt/lists/*

# ---- Two users ----
ARG RALPH_UID=1000
ARG RALPH_GID=1000
ARG TOOLS_UID=1001
ARG TOOLS_GID=1001

RUN groupadd --gid ${RALPH_GID} ralph || true && \
    useradd --uid ${RALPH_UID} --gid ${RALPH_GID} --create-home --shell /bin/sh ralph && \
    groupadd --gid ${TOOLS_GID} ralph-tools && \
    useradd --uid ${TOOLS_UID} --gid ${TOOLS_GID} --create-home --shell /bin/sh ralph-tools

# ---- Workspace dir ----
RUN mkdir -p /workspace /etc/ralph /etc/claude-defaults/hooks && \
    chown ralph:ralph /workspace

ENV DEVCONTAINER=true
WORKDIR /workspace

# ---- Node 20 (only install if the base image doesn't already have it) ----
# Many language base images don't ship Node; install our own pinned copy.
ARG NODE_VERSION=20.18.0
RUN if ! command -v node >/dev/null 2>&1 || [ "$(node -v | sed 's/^v//' | cut -d. -f1)" -lt 20 ]; then \
      ARCH=$(dpkg --print-architecture) && \
      case "$ARCH" in \
        arm64) NODE_ARCH=arm64 ;; \
        amd64) NODE_ARCH=x64 ;; \
        *) echo "Unsupported arch: $ARCH" >&2; exit 1 ;; \
      esac && \
      curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${NODE_ARCH}.tar.xz" -o /tmp/node.tar.xz && \
      mkdir -p /opt/node && \
      tar -xJf /tmp/node.tar.xz -C /opt/node --strip-components=1 && \
      rm /tmp/node.tar.xz && \
      ln -sf /opt/node/bin/node /usr/local/bin/node && \
      ln -sf /opt/node/bin/npm /usr/local/bin/npm && \
      ln -sf /opt/node/bin/npx /usr/local/bin/npx ; \
    fi

# ---- Claude Code (pinned) ----
ARG CLAUDE_CODE_VERSION=latest
RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}

# ---- ralph-tools MCP server ----
# Source is copied from the build context (host's `.ralph/build-context/ralph-tools/`).
# Production deploys should publish a versioned release tarball and verify by sha256.
# For now, COPY from the build context with strict ownership.
COPY ralph-tools/ /opt/ralph-tools/
RUN cd /opt/ralph-tools && \
    npm install --omit=dev --no-audit --no-fund && \
    chown -R root:root /opt/ralph-tools && \
    find /opt/ralph-tools -type f -exec chmod a-w {} + && \
    find /opt/ralph-tools -type d -exec chmod a-w {} + && \
    chmod 0755 /opt/ralph-tools/bin/ralph-tools

# ---- Project-declared MCP servers ----
# Generated by the launcher into the build context as `mcp-install.sh`.
ARG MCP_INSTALL_SCRIPT_PRESENT=0
COPY mcp-install.sh /tmp/mcp-install.sh
RUN if [ "${MCP_INSTALL_SCRIPT_PRESENT}" = "1" ]; then \
      sh -e /tmp/mcp-install.sh ; \
    fi && \
    rm /tmp/mcp-install.sh

# ---- Default claude settings (immutable; bind-mounted ro at runtime) ----
COPY claude-settings.json /etc/claude-defaults/settings.json

# ---- Firewall script (used by the init container, not the workload container) ----
COPY init-firewall.sh /usr/local/bin/init-firewall.sh
RUN chmod 0755 /usr/local/bin/init-firewall.sh

# ---- Project-supplied install_cmd dependencies ----
# The launcher copies the project's lockfile (Gemfile.lock, package-lock.json, etc.)
# into the build context and runs install_cmd here, so the running container has
# zero need to fetch deps from the registry at loop time.
# Skipped if install_cmd produces no output or the project doesn't ship a lockfile.
# This is opt-in via build arg.
ARG RUN_INSTALL_AT_BUILD=0
ARG INSTALL_CMD=""
RUN if [ "${RUN_INSTALL_AT_BUILD}" = "1" ] && [ -n "${INSTALL_CMD}" ]; then \
      cd /workspace && sh -c "${INSTALL_CMD}" ; \
    fi || true

# ---- Drop to ralph user. No sudoers, no NOPASSWD. ----
USER ralph

ENV SHELL=/bin/sh
ENV NPM_CONFIG_PREFIX=/home/ralph/.npm-global
ENV PATH=/home/ralph/.npm-global/bin:/opt/node/bin:/usr/local/bin:/usr/bin:/bin
ENV CLAUDE_CONFIG_DIR=/home/ralph/.claude
